{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/Button/**",
              "components/Chip/**",
              "components/Eyebrow/**",
              "components/Tile/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|arrow|href|children|className|style|key|ref)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, arrow, href, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|glass|dark|gradient)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'glass' | 'dark' | 'gradient'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Button> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|checked|onDark|style|key|ref|className)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, checked, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|dot|onDark|style|key|ref|className)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, dot, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tile'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|titleAccent|body|surface|children|style|key|ref|className)$/]",
        "message": "<Tile> doesn't accept that prop. Declared props: eyebrow, title, titleAccent, body, surface, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tile'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:ink|light)$/]",
        "message": "<Tile> surface must be one of 'ink' | 'light'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Button": {
        "replaces": []
      },
      "Chip": {
        "replaces": []
      },
      "Eyebrow": {
        "replaces": []
      },
      "Tile": {
        "replaces": []
      }
    },
