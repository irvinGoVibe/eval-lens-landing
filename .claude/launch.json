{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["serve.py", "5173"],
      "port": 5173
    },
    {
      "name": "web",
      "cwd": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "port": 3005,
      "autoPort": false
    },
    {
      "name": "web-prod",
      "cwd": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "next", "start", "--port", "3007"],
      "port": 3007,
      "autoPort": false
    },
    {
      "name": "web-qa",
      "cwd": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "next", "dev", "--port", "3011"],
      "port": 3011,
      "autoPort": false
    },
    {
      "name": "designs",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "4311", "--directory", "designs"],
      "port": 4311
    },
    {
      "name": "designs-claude",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "4312", "--directory", ".claude/designs"],
      "port": 4312
    }
  ]
}
