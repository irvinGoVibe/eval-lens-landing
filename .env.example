# EvalLense Landing — переменные окружения
#
# Правила:
# - реальные значения живут в .env (в .gitignore, никогда не коммитится)
# - этот файл — каркас: имена переменных с пустыми значениями и комментариями
# - секреты (ключи провайдеров, service-ключи БД) — только серверные переменные,
#   в клиентский бандл не попадают
#
# Секции заполняются при bootstrap под стек проекта (Next.js 16 (App Router, TS, Tailwind v4, React 19, react-three-fiber) в web/ + legacy статика index.html/serve.py).

# --- App ---
# Базовый URL самого сайта-лендинга
# NEXT_PUBLIC_APP_URL=
# URL основного продукта/приложения EvalLense (цель CTA)
# NEXT_PUBLIC_PRODUCT_URL=

# --- Database / CMS (Supabase) ---
# Контент блога (статьи + loop-посты + медиа) живёт в Supabase, не в коде.
# URL проекта и публичный anon-ключ (попадают в клиентский бандл — это НЕ секрет;
# приватность чтения обеспечивает RLS «только status = published»).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Секрет для ревалидации кэша. Supabase Database Webhook шлёт его в заголовке
# x-revalidate-secret на POST /api/revalidate; handler сверяет. Только server-side.
REVALIDATE_SECRET=
# Источник контента блога: supabase (по умолчанию) | static (in-repo fallback).
# BLOG_SOURCE=supabase

# --- CMS Admin (Story 02; только server-side) ---
# Пароль для входа в админку /admin (один общий пароль, без аккаунтов).
# Сверяется только на сервере; в клиентский бандл не попадает. В куку пишется
# не сам пароль, а его SHA-256-дайджест (httpOnly-сессия).
CMS_PASSWORD=
# service_role-ключ Supabase: обходит RLS, используется ТОЛЬКО server-side для
# записи (CRUD статей/репостов, выбор статей для блока на главной, upload медиа).
# НИКОГДА не должен попасть в клиентский код.
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth ---
# не используется: аутентификации на сайте нет

# --- AI providers (только server-side) ---
# не используется: pipeline оценки живёт вне этого сайта

# --- Analytics (планируется) ---
# Провайдер не выбран; добавить ключ/домен после выбора
# NEXT_PUBLIC_ANALYTICS_ID=

# --- Lead form → email/CRM (планируется, server-side) ---
# Эндпоинт/ключ приёма заявки (waitlist/демо); провайдер не выбран
# FORM_ENDPOINT_URL=
# FORM_API_KEY=
